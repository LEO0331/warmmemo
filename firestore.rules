rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isRoleAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow write: if request.auth.uid == userId;

      match /drafts/{draftId} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true;
      }

      match /meta/{metaDoc} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true;
      }

      match /orders/{orderId} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true || isRoleAdmin();
      }
    }

    // Backward compatible: root-level orders/{orderId}
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || request.auth.token.admin == true || isRoleAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (request.auth.token.admin == true || isRoleAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if request.auth.uid == resource.data.userId || request.auth.token.admin == true;
      allow create:
        if (request.auth.token.admin == true) ||
           (request.auth.uid != null && request.auth.uid == request.resource.data.userId);
      allow update, delete: if request.auth.token.admin == true;
    }
  }
}
