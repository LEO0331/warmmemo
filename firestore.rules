rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow write: if request.auth.uid == userId;

      match /drafts/{draftId} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true;
      }

      match /meta/{metaDoc} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true;
      }

      match /orders/{orderId} {
        allow read, write: if request.auth.uid == userId
          || request.auth.token.admin == true
          || (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      }
    }

    match /notifications/{notificationId} {
      allow read: if request.auth.uid == resource.data.userId || request.auth.token.admin == true;
      allow create:
        if (request.auth.token.admin == true) ||
           (request.auth.uid != null && request.auth.uid == request.resource.data.userId);
      allow update, delete: if request.auth.token.admin == true;
    }
  }
}
