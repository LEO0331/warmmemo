rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Use a dedicated admins collection to avoid per-document get() cost in list queries.
    function isAdminDoc() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /users/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true || isAdminDoc();
      allow write: if request.auth.uid == userId;

      match /drafts/{draftId} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true || isAdminDoc();
      }

      match /meta/{metaDoc} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true || isAdminDoc();
      }

      match /orders/{orderId} {
        allow read, write: if request.auth.uid == userId || request.auth.token.admin == true || isAdminDoc();
      }
    }

    // Backward compatible: root-level orders/{orderId}
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId || request.auth.token.admin == true || isAdminDoc()
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (request.auth.token.admin == true || isAdminDoc());
    }

    match /notifications/{notificationId} {
      allow read: if request.auth.uid == resource.data.userId || request.auth.token.admin == true || isAdminDoc();
      allow create:
        if (request.auth.token.admin == true || isAdminDoc()) ||
           (request.auth.uid != null && request.auth.uid == request.resource.data.userId);
      allow update, delete: if request.auth.token.admin == true || isAdminDoc();
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      // Only admins (by token) can manage admins docs.
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
