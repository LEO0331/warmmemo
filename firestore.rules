rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTokenAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isAdminDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return isTokenAdmin() || isAdminDoc();
    }

    function ownerOrderUpdatableKeysOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'paymentProvider',
        'paymentStatus',
        'invoiceId',
        'checkoutUrl',
        'paymentCurrency',
        'proposal'
      ]);
    }

    function ownerOrderPaymentStatusAllowed() {
      return !(request.resource.data.paymentStatus in ['paid']);
    }

    function ownerOrderProposalShapeValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['proposal'])
        || (
          request.resource.data.proposal == null
          || (
            request.resource.data.proposal is map
            && request.resource.data.proposal.keys().hasOnly([
              'vendorPreference',
              'materialChoice',
              'schedulePreference',
              'note',
              'submittedAt'
            ])
            && (
              !('vendorPreference' in request.resource.data.proposal)
              || request.resource.data.proposal.vendorPreference is string
              || request.resource.data.proposal.vendorPreference == null
            )
            && (
              !('materialChoice' in request.resource.data.proposal)
              || request.resource.data.proposal.materialChoice is string
              || request.resource.data.proposal.materialChoice == null
            )
            && (
              !('schedulePreference' in request.resource.data.proposal)
              || request.resource.data.proposal.schedulePreference is string
              || request.resource.data.proposal.schedulePreference == null
            )
            && (
              !('note' in request.resource.data.proposal)
              || request.resource.data.proposal.note is string
              || request.resource.data.proposal.note == null
            )
            && (
              !('submittedAt' in request.resource.data.proposal)
              || request.resource.data.proposal.submittedAt is string
              || request.resource.data.proposal.submittedAt == null
            )
          )
        );
    }

    function ownerUserSafeUpdate(userId) {
      return isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role',
          'tokenBalance',
          'tokenGrantedAt',
          'tokenUpdatedAt'
        ]);
    }

    function ownerTokenConsumeUpdate(userId) {
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'tokenBalance',
          'tokenUpdatedAt'
        ])
        && request.resource.data.tokenBalance is int
        && resource.data.tokenBalance is int
        && request.resource.data.tokenBalance == resource.data.tokenBalance - 1
        && request.resource.data.tokenBalance >= 0;
    }

    function ownerTokenBootstrapUpdate(userId) {
      return isOwner(userId)
        && !(resource.data.tokenBalance is int)
        && request.resource.data.tokenBalance == 5
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'email',
          'updatedAt',
          'role',
          'tokenBalance',
          'tokenGrantedAt',
          'tokenUpdatedAt'
        ])
        && (
          (resource.data.role is string && request.resource.data.role == resource.data.role)
          || (!(resource.data.role is string) && request.resource.data.role == 'user')
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.tokenBalance == 5;
      allow update: if ownerUserSafeUpdate(userId)
        || ownerTokenBootstrapUpdate(userId)
        || ownerTokenConsumeUpdate(userId)
        || isAdmin();
      allow delete: if isAdmin();

      match /drafts/{draftId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /meta/{metaDoc} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.status == 'pending'
          && request.resource.data.paymentStatus in ['awaiting_checkout', 'checkout_created', 'failed', 'cancelled', 'expired'];
        allow update: if (isOwner(userId)
            && ownerOrderUpdatableKeysOnly()
            && ownerOrderPaymentStatusAllowed()
            && ownerOrderProposalShapeValid())
          || isAdmin();
        allow delete: if isAdmin();
      }

      match /tokenLogs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if (isOwner(userId)
            && request.resource.data.type == 'consume'
            && request.resource.data.cost == 1)
          || isAdmin();
        allow update, delete: if isAdmin();
      }

      match /cyberSkills/{skillId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin())
          && request.resource.data.keys().hasOnly([
            'templateType',
            'profileName',
            'profileIdentity',
            'analysisSummary',
            'markdown',
            'version',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.templateType in ['warmmemoDaily', 'colleagueWork']
          && request.resource.data.profileName is string
          && request.resource.data.profileIdentity is string
          && request.resource.data.analysisSummary is map
          && request.resource.data.markdown is string
          && request.resource.data.version is string
          && request.resource.data.createdAt is string
          && request.resource.data.updatedAt is string;
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /topupRequests/{requestId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.status == 'pending'
          && request.resource.data.requestedTokens is int
          && request.resource.data.requestedTokens > 0
          && request.resource.data.requestedTokens <= 1000;
        allow update, delete: if isAdmin();
      }
    }

    // Admin-only catch-all for any orders subcollection path.
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }

    // Backward compatible: root-level orders/{orderId}
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || isAdmin()
      );
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.status == 'pending'
        && request.resource.data.paymentStatus in ['awaiting_checkout', 'checkout_created', 'failed', 'cancelled', 'expired'];
      allow update: if (isSignedIn()
          && request.auth.uid == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'paymentProvider',
            'paymentStatus',
            'invoiceId',
            'checkoutUrl',
            'paymentCurrency',
            'proposal'
          ])
          && !(request.resource.data.paymentStatus in ['paid'])
          && ownerOrderProposalShapeValid())
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /vendors/{vendorId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAdmin()
        || (isSignedIn() && request.auth.uid == request.resource.data.userId);
      allow update: if isAdmin()
        || (isSignedIn()
          && request.auth.uid == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt'])
          && request.resource.data.status == 'read');
      allow delete: if isAdmin();
    }

    match /public_memorials/{slug} {
      allow read: if true;
      allow create: if isSignedIn()
        && (request.auth.uid == request.resource.data.ownerUid || isAdmin());
      allow update: if isSignedIn()
        && (
          isAdmin()
          || (
            request.auth.uid == resource.data.ownerUid
            && request.auth.uid == request.resource.data.ownerUid
          )
        );
      allow delete: if isSignedIn()
        && (isAdmin() || request.auth.uid == resource.data.ownerUid);
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow create: if isSignedIn()
        && request.auth.uid == adminId
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if isTokenAdmin();
    }
  }
}
